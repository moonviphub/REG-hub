]]

-- TOGGLE
local Visible = true

Open.MouseButton1Click:Connect(function()

    Visible = not Visible

    Main.Visible = Visible

end)

-- SIMPLE ANIMATION
task.spawn(function()

    while task.wait() do

        TweenService:Create(
            Stroke,
            TweenInfo.new(1),
            {
                Transparency = 0.2
            }
        ):Play()

        task.wait(1)

        TweenService:Create(
            Stroke,
            TweenInfo.new(1),
            {
                Transparency = 0.5
            }
        ):Play()

    end
end)

print("TRZ UI LOADED")
