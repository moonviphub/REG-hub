-- AUTO FARM
local function startFarm()

    farming = true

    task.spawn(function()

        while farming do

            local chests = getChests()

            Status.Text = "Status : Found "..#chests.." Chests"

            if #chests == 0 then

                Status.Text = "Status : No Chest Found"

                task.wait(3)

            end

            for _, chest in ipairs(chests) do

                if not farming then
                    break
                end

                Status.Text = "Status : Farming "..chest.Name

                teleportTo(chest)

                print("Teleporting To :", chest.Name)

                -- đợi nhặt
                task.wait(2)

            end

            Status.Text = "Status : Refreshing"

            task.wait(2)

        end
    end)
end
