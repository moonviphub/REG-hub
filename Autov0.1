--// CHEST POSITIONS
-- THAY TỌA ĐỘ THẬT Ở ĐÂY

local chestPositions = {

    Vector3.new(100,20,300),
    Vector3.new(-250,15,420),
    Vector3.new(600,10,-120)

}

--// FARM LOGIC

local farming = false
local isToggled = false

local tweenInfo = TweenInfo.new(
    0.3,
    Enum.EasingStyle.Quart,
    Enum.EasingDirection.Out
)

local function teleportTo(pos)

    local character = Player.Character

    if character and character:FindFirstChild("HumanoidRootPart") then

        local hrp = character.HumanoidRootPart

        -- spam TP chống snapback
        for i = 1,3 do

            hrp.CFrame = CFrame.new(pos + Vector3.new(0,3,0))

            task.wait(0.1)

        end
    end
end

local function startFarm()

    farming = true

    task.spawn(function()

        while farming do

            for _, pos in ipairs(chestPositions) do

                if not farming then
                    break
                end

                Status.Text = "Status : Farming Chest"

                teleportTo(pos)

                print("Teleport :", pos)

                -- chờ nhặt chest
                task.wait(2)

            end

            Status.Text = "Status : Finished Route"

            print("Finished Chest Route")

            task.wait(1)

        end
    end)
end

local function stopFarm()

    farming = false

    Status.Text = "Status : Idle"

end

--// TOGGLE

ToggleBg.MouseButton1Click:Connect(function()

    isToggled = not isToggled

    if isToggled then

        FarmText.TextColor3 = Color3.new(1,1,1)

        TweenService:Create(
            ToggleBg,
            tweenInfo,
            {BackgroundColor3 = Color3.fromRGB(0,200,80)}
        ):Play()

        TweenService:Create(
            ToggleCircle,
            tweenInfo,
            {Position = UDim2.new(1,-18,0.5,-8)}
        ):Play()

        Status.Text = "Status : Starting Farm"

        startFarm()

    else

        FarmText.TextColor3 = Color3.fromRGB(200,200,200)

        TweenService:Create(
            ToggleBg,
            tweenInfo,
            {BackgroundColor3 = Color3.fromRGB(60,60,60)}
        ):Play()

        TweenService:Create(
            ToggleCircle,
            tweenInfo,
            {Position = UDim2.new(0,2,0.5,-8)}
        ):Play()

        stopFarm()

    end
end)

