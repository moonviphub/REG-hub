-- LEVEL SYSTEM
local function UpdateQuest()

    local Level = 1

    pcall(function()
        Level = Player.Data.Level.Value
    end)

    local Text = ""

    if Level >= 625 and Level <= 649 then

        Text =
[[LEVEL : ]]..Level..[[

QUEST :
Snow Trooper

ISLAND :
Ice Castle]]

    elseif Level >= 650 and Level <= 699 then

        Text =
[[LEVEL : ]]..Level..[[

QUEST :
Lab Subordinate

ISLAND :
Hot & Cold]]

    else

        Text =
[[LEVEL : ]]..Level..[[

No quest data yet.]]

    end

    QuestInfo.Text = Text
end

UpdateQuest()

-- UPDATE LOOP
task.spawn(function()

    while task.wait(3) do
        pcall(UpdateQuest)
    end

end)

