-- FALL DETECT
task.spawn(function()

    while task.wait() do

        if HRP.Position.Y < -30 then

            Falls += 1

            Counter.Text = "FALLS : "..Falls

            Status.Text = "STATUS : SLAPPED BY REALITY"

            task.wait(2)

        end

    end
end)

-- JACKPOT
local Jackpot = false

Spin.MouseButton1Click:Connect(function()

    Status.Text = "STATUS : SPINNING"

    local rolls = {
        "LOSE",
        "LOSE",
        "777",
        "LOSE",
        "LOSE"
    }

    for i = 1,18 do

        Result.Text = rolls[math.random(1,#rolls)]

        task.wait(0.08)

    end

    if math.random(1,7) == 1 then

        Jackpot = true

        Result.Text = "★ JACKPOT ★"

        Status.Text = "STATUS : DOMAIN EXPANSION"

        Rewind.Visible = true

        for i = 1,6 do

            Main.BackgroundColor3 = Color3.fromRGB(255,40,40)

            task.wait(0.08)

            Main.BackgroundColor3 = Color3.fromRGB(0,90,255)

            task.wait(0.08)

        end

        Main.BackgroundColor3 = Color3.fromRGB(10,10,15)

    else

        Jackpot = false

        Result.Text = "YOU WON NOTHING"

        Status.Text = "STATUS : SAD"

    end

end)

-- REWIND
Rewind.MouseButton1Click:Connect(function()

    if Jackpot then

        HRP.CFrame = LastCheckpoint

        Status.Text = "STATUS : TIME REVERSED"

        Result.Text = "LUCK SAVED YOU"

    end

end)

