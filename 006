--// hiruZ Hub - Part 1 (Core)

local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local UIS = game:GetService("UserInputService")
local Workspace = game:GetService("Workspace")
local VirtualUser = game:GetService("VirtualUser")

local player = Players.LocalPlayer

--// Character
local function getChar()
    return player.Character or player.CharacterAdded:Wait()
end

local function getRoot()
    return getChar():WaitForChild("HumanoidRootPart")
end

--// CONFIG
local Config = {
    AutoFarm = false,
    StackFarm = false,
    ItemFarm = false,
    ComboMode = true,
    SmartDash = true,

    DashDistance = 25,
    StackRange = 30,

    ThemeColor = Color3.fromRGB(0,170,255)
}

--// THEME
local Theme = {
    BG = Color3.fromRGB(20,20,20),
    Sidebar = Color3.fromRGB(15,15,15),
    Btn = Color3.fromRGB(30,30,30),
    Accent = Config.ThemeColor,
    Text = Color3.new(1,1,1)
}

--// Tween helper
local function tween(obj, goal)
    TweenService:Create(obj, TweenInfo.new(0.2), goal):Play()
end

--// Notify (console)
local function notify(msg)
    print("[hiruZ]: "..msg)
end--// UI

local ScreenGui = Instance.new("ScreenGui", game.CoreGui)

local Main = Instance.new("Frame", ScreenGui)
Main.Size = UDim2.new(0,500,0,300)
Main.Position = UDim2.new(0.5,-250,0.5,-150)
Main.BackgroundColor3 = Theme.BG

-- Drag
local dragging, dragStart, startPos

Main.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = Main.Position
    end
end)

UIS.InputChanged:Connect(function(input)
    if dragging then
        local delta = input.Position - dragStart
        Main.Position = UDim2.new(
            startPos.X.Scale,
            startPos.X.Offset + delta.X,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y
        )
    end
end)

UIS.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

-- Sidebar
local Sidebar = Instance.new("Frame", Main)
Sidebar.Size = UDim2.new(0,120,1,0)
Sidebar.BackgroundColor3 = Theme.Sidebar

-- Container
local Container = Instance.new("Frame", Main)
Container.Position = UDim2.new(0,120,0,0)
Container.Size = UDim2.new(1,-120,1,0)
Container.BackgroundTransparency = 1

-- Tabs
local function createTab()
    local f = Instance.new("Frame", Container)
    f.Size = UDim2.new(1,0,1,0)
    f.Visible = false
    return f
end

local FarmTab = createTab()
local MiscTab = createTab()

FarmTab.Visible = true

-- Buttons
local function createTabBtn(name, y)
    local btn = Instance.new("TextButton", Sidebar)
    btn.Size = UDim2.new(1,0,0,40)
    btn.Position = UDim2.new(0,0,0,y)
    btn.Text = name
    btn.BackgroundColor3 = Theme.Btn
    btn.TextColor3 = Theme.Text
    return btn
end

local FarmBtn = createTabBtn("Farm",0)
local MiscBtn = createTabBtn("Misc",40)

-- Switch
local function switch(tab)
    FarmTab.Visible = false
    MiscTab.Visible = false
    tab.Visible = true
end

FarmBtn.MouseButton1Click:Connect(function() switch(FarmTab) end)
MiscBtn.MouseButton1Click:Connect(function() switch(MiscTab) end)-- Toggle
local function createToggle(parent, text, default, callback)
    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(0,220,0,35)

    local state = default

    local function update()
        btn.Text = text.." ["..(state and "ON" or "OFF").."]"
        btn.BackgroundColor3 = state and Theme.Accent or Theme.Btn
    end

    btn.MouseButton1Click:Connect(function()
        state = not state
        update()
        callback(state)
    end)

    update()
end

-- Create toggles
createToggle(FarmTab, "Auto Farm", false, function(v)
    Config.AutoFarm = v
end)

createToggle(FarmTab, "Stack Farm", false, function(v)
    Config.StackFarm = v
end)

createToggle(FarmTab, "Item Farm", false, function(v)
    Config.ItemFarm = v
end)local Vim = game:GetService("VirtualInputManager")

local function press(k)
    Vim:SendKeyEvent(true,k,false,game)
    task.wait(0.05)
    Vim:SendKeyEvent(false,k,false,game)
end

local function doCombo()
    press("Z")
    press("X")
    press("C")
end

-- Target mob
local function getMob()
    for _,v in pairs(Workspace:GetDescendants()) do
        if v:IsA("Model") and v:FindFirstChild("Humanoid") then
            if v.Humanoid.Health > 0 then
                return v:FindFirstChild("HumanoidRootPart")
            end
        end
    end
end

-- Smart Dash
local lastDash = 0

local function dash(target)
    if tick() - lastDash < 0.8 then return end

    local root = getRoot()
    local dist = (target.Position - root.Position).Magnitude

    if dist < Config.DashDistance then
        root.CFrame = target.CFrame * CFrame.new(0,3,5)
        lastDash = tick()
    end
end-- Item
local function getItem()
    for _,v in pairs(Workspace:GetDescendants()) do
        if string.find(v.Name,"Fruit") or string.find(v.Name,"Chest") then
            return v
        end
    end
end

-- MAIN LOOP
task.spawn(function()
    while task.wait(0.2) do
        local root = getRoot()
        if not root then continue end

        -- FARM
        if Config.AutoFarm then
            local mob = getMob()

            if mob then
                root.CFrame = mob.CFrame * CFrame.new(0,10,0)

                if Config.ComboMode then
                    doCombo()
                end

                if Config.SmartDash then
                    dash(mob)
                end
            end
        end

        -- ITEM
        if Config.ItemFarm then
            local item = getItem()
            if item then
                root.CFrame = item.CFrame * CFrame.new(0,2,0)
            end
        end
    end
end)

