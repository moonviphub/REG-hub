CircleCorner.Parent = ToggleCircle

-- Nút Hop Server
local HopButton = Instance.new("TextButton")
HopButton.Size = UDim2.new(0, 230, 0, 30)
HopButton.Position = UDim2.new(0.5, -115, 0, 85)
HopButton.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
HopButton.Text = "HOP SERVER"
HopButton.TextColor3 = Color3.fromRGB(255, 255, 255)
HopButton.TextSize = 14
HopButton.Font = Enum.Font.GothamBold
HopButton.Parent = MainFrame

local HopCorner = Instance.new("UICorner")
HopCorner.CornerRadius = UDim.new(0, 6)
HopCorner.Parent = HopButton

-- Logic Nút Gạt (Animation mượt như Krnl)
local isToggled = false
local tweenInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)

ToggleBg.MouseButton1Click:Connect(function()
    isToggled = not isToggled
    if isToggled then
        -- Trạng thái BẬT
        FarmText.TextColor3 = Color3.fromRGB(255, 255, 255)
        TweenService:Create(ToggleBg, tweenInfo, {BackgroundColor3 = Color3.fromRGB(0, 200, 80)}):Play()
        TweenService:Create(ToggleCircle, tweenInfo, {Position = UDim2.new(1, -18, 0.5, -8)}):Play()
        print("Đã BẬT Auto Farm Chest!")
        -- Chèn function gọi code farm của ông vào đây
    else
        -- Trạng thái TẮT
        FarmText.TextColor3 = Color3.fromRGB(200, 200, 200)
        TweenService:Create(ToggleBg, tweenInfo, {BackgroundColor3 = Color3.fromRGB(60, 60, 60)}):Play()
        TweenService:Create(ToggleCircle, tweenInfo, {Position = UDim2.new(0, 2, 0.5, -8)}):Play()
        print("Đã TẮT Auto Farm Chest!")
        -- Chèn function dừng code farm vào đây
    end
end)

-- Logic Nút Hop Server
HopButton.MouseButton1Click:Connect(function()
    print("Đang tìm server mới...")
    -- Chèn code Hop Server của ông vào đây
end)

-- Code làm mượt nút bấm
HopButton.MouseEnter:Connect(function()
    TweenService:Create(HopButton, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(60, 60, 60)}):Play()
end)
HopButton.MouseLeave:Connect(function()
    TweenService:Create(HopButton, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(40, 40, 40)}):Play()
end)
