--// SETTINGS
local AutoParry = false

local MainRange = 25
local BackupRange = 12

local LastParry = 0
local SpamDelay = 0.05

--// FIND BALL
local function getBall()

    for _,v in pairs(workspace:GetChildren()) do

        if v:IsA("Part") then

            if string.find(v.Name:lower(),"ball") then
                return v
            end

        end
    end

    return nil
end

--// PARRY
local function parry()

    if tick() - LastParry < SpamDelay then
        return
    end

    LastParry = tick()

    mouse1press()
    task.wait()
    mouse1release()

    Status.Text = "Status : Parry"

end

--// AI LOOP
game:GetService("RunService").RenderStepped:Connect(function()

    if not AutoParry then
        return
    end

    local Character = Player.Character

    if not Character then
        return
    end

    local HRP = Character:FindFirstChild("HumanoidRootPart")

    if not HRP then
        return
    end

    local Ball = getBall()

    if not Ball then

        Status.Text = "Status : No Ball"

        return
    end

    local Distance = (Ball.Position - HRP.Position).Magnitude

    local Velocity = Ball.AssemblyLinearVelocity.Magnitude

    -- MAIN AI
    if Distance <= MainRange then

        local Predict = Velocity / 15

        if Distance <= Predict + 10 then

            parry()

        end
    end

    -- BACKUP AI
    if Distance <= BackupRange then

        parry()

    end

end)

