    print("Anti-AFK: Da kich hoat de tranh bi kick!")
end)

-- 2. INVISIBLE & IMMORTAL (Tàng hình 1P + Bất tử sau khi dịch chuyển)
function ApplyGhostMode()
    local char = game.Players.LocalPlayer.Character
    if char then
        -- Tàng hình (Transparency) và Bất tử (ForceField)
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then part.Transparency = 1 end
            if part:IsA("Decal") then part.Transparency = 1 end -- Không tạo ảnh
        end
        local ff = Instance.new("ForceField", char)
        print("Trạng thái Hư Thức: Bat dau 60s!")
        
        task.wait(60) -- Duy trì trong 1 phút
        ff:Destroy()
        -- Reset lại hiển thị ở đây
    end
end

-- 3. UNIVERSAL AIMLOCK (Khóa mục tiêu cho mọi game)
