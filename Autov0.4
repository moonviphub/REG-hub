--// FARM SYSTEM
local farming = false
local isToggled = false

local tweenInfo = TweenInfo.new(
    0.3,
    Enum.EasingStyle.Quart,
    Enum.EasingDirection.Out
)

--// FIND CHESTS
local function getChests()

    local chests = {}

    for _, v in pairs(workspace:GetDescendants()) do

        if string.find(v.Name:lower(), "chest") then

            if v:IsA("BasePart") then

                table.insert(chests, v)

            elseif v:IsA("Model") then

                local part = v:FindFirstChildWhichIsA("BasePart")

                if part then
                    table.insert(chests, part)
                end
            end
        end
    end

    return chests
end

--// TELEPORT
local function teleportTo(chest)

    local character = Player.Character
    if not character then return end

    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local target = chest.Position + Vector3.new(0,5,0)

    -- lên trên chest trước
    hrp.CFrame = CFrame.new(target)

    task.wait(1)

    -- rơi xuống chest
    hrp.CFrame = chest.CFrame + Vector3.new(0,1,0)

    task.wait(1.5)

end

--// AUTO FARM
local function startFarm()

    farming = true

    task.spawn(function()

        while farming do

            local chests = getChests()

            Status.Text = "Status : "..#chests.." Chests"

            if #chests == 0 then

                task.wait(3)

            end

            for _, chest in ipairs(chests) do

                if not farming then
                    break
                end

                Status.Text = "Status : Looting"

                teleportTo(chest)

                print("Looting :", chest.Name)

                task.wait(2)

            end

            Status.Text = "Status : Refresh"

            task.wait(2)

        end
    end)
end

--// STOP FARM
local function stopFarm()

    farming = false

    Status.Text = "Status : Idle"

end

--// TOGGLE LOGIC
ToggleBg.MouseButton1Click:Connect(function()

    isToggled = not isToggled

    if isToggled then

        FarmText.TextColor3 = Color3.new(1,1,1)

        TweenService:Create(
            ToggleBg,
            tweenInfo,
            {BackgroundColor3 = Color3.fromRGB(0,200,80)}
        ):Play()

        TweenService:Create(
            ToggleCircle,
            tweenInfo,
            {Position = UDim2.new(1,-18,0.5,-8)}
        ):Play()

        startFarm()

    else

        FarmText.TextColor3 = Color3.fromRGB(200,200,200)

        TweenService:Create(
            ToggleBg,
            tweenInfo,
            {BackgroundColor3 = Color3.fromRGB(60,60,60)}
        ):Play()

        TweenService:Create(
            ToggleCircle,
            tweenInfo,
            {Position = UDim2.new(0,2,0.5,-8)}
        ):Play()

        stopFarm()

    end
end)

